{
  "name": "shelters-horizon-api",
  "version": "4.0.0",
  "description": "Shelters Horizon — Node.js + Express + Prisma + Supabase",
  "type": "commonjs",
  "main": "dist/server.js",
  "scripts": {
    "dev":         "tsx watch src/server.ts",
    "build":       "tsc",
    "start":       "node dist/server.js",
    "db:generate": "prisma generate",
    "db:push":     "prisma db push",
    "db:migrate":  "prisma migrate dev",
    "db:studio":   "prisma studio",
    "db:seed":     "tsx src/prisma/seed.ts"
  },
  "dependencies": {
    "express":               "^4.19.2",
    "express-async-errors":  "^3.1.1",
    "cors":                  "^2.8.5",
    "helmet":                "^7.1.0",
    "compression":           "^1.7.4",
    "morgan":                "^1.10.0",
    "express-rate-limit":    "^7.3.1",
    "@prisma/client":        "^5.15.0",
    "@supabase/supabase-js": "^2.43.4",
    "jsonwebtoken":          "^9.0.2",
    "multer":                "^1.4.5-lts.1",
    "socket.io":             "^4.7.5",
    "winston":               "^3.13.0",
    "dotenv":                "^16.4.5",
    "slugify":               "^1.6.6",
    "uuid":                  "^10.0.0"
  },
  "devDependencies": {
    "prisma":             "^5.15.0",
    "@types/express":     "^4.17.21",
    "@types/cors":        "^2.8.17",
    "@types/compression": "^1.7.5",
    "@types/morgan":      "^1.9.9",
    "@types/jsonwebtoken":"^9.0.6",
    "@types/multer":      "^1.4.11",
    "@types/uuid":        "^10.0.0",
    "@types/node":        "^20.14.2",
    "typescript":         "^5.4.5",
    "tsx":                "^4.15.1"
  }
}
